# Backend environment (copy to backend/.env)
PORT=5001
JWT_SECRET=change-me-in-production
DATABASE_URL="file:./dev.db"

# Cloudflare R2 (optional — patient document uploads)
# When unset, documents are stored as base64 in SQLite (local dev)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=magil-clinic-documents
# R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
