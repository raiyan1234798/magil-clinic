{
  "name": "magil-clinic-api-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "predeploy": "cd ../backend && npx prisma generate && mkdir -p ../worker/node_modules/.prisma && cp -r node_modules/.prisma/client ../worker/node_modules/.prisma/",
    "deploy": "npm run predeploy && wrangler deploy",
    "dev": "wrangler dev"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@mjackson/node-fetch-server": "^0.7.0",
    "@prisma/adapter-d1": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@whatwg-node/server": "^0.11.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "hono": "^4.12.27",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250605.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.75.0"
  }
}
