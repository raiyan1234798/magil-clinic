# Backend environment (copy to backend/.env)
PORT=5001
JWT_SECRET=change-me-in-production
DATABASE_URL="file:./dev.db"

# Comma-separated origins allowed for CORS (include your CF Pages URL)
CORS_ORIGIN=http://localhost:3000,https://magil-clinic.pages.dev

# Production (Render/Railway): set DATABASE_URL to a persistent path, e.g. file:./data/dev.db

# Cloudflare R2 (optional — patient document uploads)
# When unset, documents are stored as base64 in SQLite (local dev)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=magil-clinic-documents
# R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
